{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build C++ program",
            "type": "shell",
            "command": "g++",
            "args": [
                "-o",
                "${workspaceFolder}/bin/${fileBasenameNoExtension}",
                "${file}"
            ],
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "G:\\compiler\\x86_64-mingw\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
